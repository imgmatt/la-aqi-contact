# Caddy config for Railway. Railway injects $PORT; default to 80 for local runs.
:{$PORT:80} {
	root * /srv
	file_server
	encode gzip zstd

	# Single-page app: serve index.html for any unmatched path.
	try_files {path} /index.html

	header {
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}

	log {
		output stdout
		format console
	}
}
